  <!-- ═══════════════════════════════════════
       FONTS
  ═══════════════════════════════════════ -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* ═══════════════════════════════════
       RESET & BASE
    ═══════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      background: #F4F0E8;
      color: #13110C;
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      line-height: 1.6;
      overflow-x: hidden;
    }
    ::selection { background: #B83020; color: #fff; }
    ::-webkit-scrollbar { width: 3px; }
    ::-webkit-scrollbar-thumb { background: #DDD8CE; border-radius: 2px; }
    img { max-width: 100%; }
    a { color: inherit; }

    /* ── Variables ── */
    :root {
      --bg:    #F4F0E8;
      --paper: #FDFAF4;
      --white: #FFFFFF;
      --ink:   #13110C;
      --sub:   #5A554E;
      --muted: #8C877F;
      --faint: #B5B0A8;
      --line:  #DDD8CE;
      --lineS: #E8E4DC;
      --red:   #B83020;
      --navy:  #18293F;
      --green: #1A6640;
      --gold:  #96700E;
    }

    /* ── Layout ── */
    .wrap { max-width: 1080px; margin: 0 auto; padding: 0 36px; }

    /* ── Typographie ── */
    .serif { font-family: 'Cormorant Garamond', serif; }
    h1, h2, h3 { font-family: 'Cormorant Garamond', serif; font-weight: 400; line-height: 1.0; }
    h1 { font-size: clamp(44px, 6vw, 70px); letter-spacing: -0.02em; }
    h2 { font-size: clamp(32px, 4vw, 48px); letter-spacing: -0.02em; }

    /* ── Boutons ── */
    .btn-red {
      display: inline-block;
      background: var(--red);
      color: #fff;
      border: none;
      border-radius: 9px;
      padding: 15px 30px;
      font-size: 14px;
      font-weight: 600;
      font-family: 'DM Sans', sans-serif;
      letter-spacing: 0.05em;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
    }
    .btn-red:hover { opacity: 0.84; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(184,48,32,0.22); }

    .btn-ghost {
      display: inline-block;
      background: transparent;
      color: var(--sub);
      border: 1.5px solid var(--line);
      border-radius: 9px;
      padding: 14px 24px;
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
    }
    .btn-ghost:hover { background: var(--ink); color: #fff; border-color: var(--ink); }

    /* ── Pills ── */
    .pill {
      display: inline-block;
      font-size: 9px;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 20px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .pill-red   { color: var(--red);   background: rgba(184,48,32,0.09); }
    .pill-green { color: var(--green); background: rgba(26,102,64,0.09); }
    .pill-gold  { color: var(--gold);  background: rgba(150,112,14,0.10); }

    /* ── Section label ── */
    .section-label {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    .section-label .bar { width: 2px; height: 18px; background: var(--red); border-radius: 1px; }
    .section-label span {
      font-size: 10px;
      font-weight: 700;
      color: var(--red);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .section-label.light span { color: rgba(237,232,223,0.45); }
    .section-label.light .bar { background: var(--red); }

    /* ── Divider ── */
    .divider { height: 1px; background: var(--line); }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(26,102,64,0.5); }
      60%       { box-shadow: 0 0 0 8px rgba(26,102,64,0); }
    }
    .a1 { animation: fadeUp 0.8s 0.1s both ease; }
    .a2 { animation: fadeUp 0.8s 0.25s both ease; }
    .a3 { animation: fadeUp 0.8s 0.4s both ease; }
    .a4 { animation: fadeUp 0.8s 0.55s both ease; }
    .a5 { animation: fadeUp 0.8s 0.7s both ease; }
    .pulse-dot { animation: pulse 2.2s infinite; }

    /* ════════════════════════════════════
       BARRE TOP
    ════════════════════════════════════ */
    .topbar {
      background: var(--green);
      padding: 10px 24px;
      text-align: center;
      font-size: 13px;
      color: #fff;
    }
    .topbar a { color: #fff; font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }

    /* ════════════════════════════════════
       NAV
    ════════════════════════════════════ */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(244,240,232,0.97);
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(20px);
    }
    .nav-inner {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 36px;
      height: 58px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-links { display: flex; align-items: center; gap: 28px; }
    .nav-links a {
      font-size: 13px;
      color: var(--sub);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--ink); }
    .nav-phone { font-size: 13px; color: var(--sub); text-decoration: none; }

    /* ════════════════════════════════════
       LOGO SVG inline
    ════════════════════════════════════ */
    .logo-h { display: flex; align-items: center; gap: 12px; }
    .logo-divider { width: 1px; height: 34px; background: rgba(24,41,63,0.12); }
    .logo-divider-light { width: 1px; height: 34px; background: rgba(255,255,255,0.14); }
    .logo-text-wrap { display: flex; flex-direction: column; }
    .logo-opus { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 500; letter-spacing: 0.24em; line-height: 1; text-transform: uppercase; color: var(--navy); }
    .logo-opus-light { color: #EDE8DF; }
    .logo-sub { font-size: 8px; color: rgba(24,41,63,0.4); letter-spacing: 0.2em; text-transform: uppercase; margin-top: 3px; }
    .logo-sub-light { color: rgba(237,232,223,0.4); }
    .logo-v { display: flex; flex-direction: column; align-items: center; gap: 12px; }
    .logo-v-text { text-align: center; }
    .logo-v-opus { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase; line-height: 1; margin-bottom: 5px; }
    .logo-v-rule { display: flex; align-items: center; gap: 8px; justify-content: center; }
    .logo-v-line { width: 14px; height: 1px; }
    .logo-v-prev { font-size: 8.5px; letter-spacing: 0.22em; text-transform: uppercase; }

    /* ════════════════════════════════════
       HERO
    ════════════════════════════════════ */
    .hero { padding: 88px 0 80px; }
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 80px;
      align-items: center;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: rgba(26,102,64,0.09);
      border: 1px solid rgba(26,102,64,0.2);
      border-radius: 24px;
      padding: 7px 16px;
      margin-bottom: 32px;
    }
    .hero-badge .dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--green);
      flex-shrink: 0;
    }
    .hero-badge span {
      font-size: 11px;
      color: var(--green);
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .hero h1 { color: var(--ink); margin-bottom: 26px; }
    .hero h1 em { color: var(--red); font-style: italic; }
    .hero-desc { font-size: 16px; color: var(--sub); line-height: 1.85; max-width: 410px; margin-bottom: 20px; }
    .hero-opco {
      display: inline-flex;
      align-items: flex-start;
      gap: 12px;
      background: rgba(150,112,14,0.10);
      border: 1px solid rgba(150,112,14,0.2);
      border-radius: 12px;
      padding: 12px 16px;
      margin-bottom: 36px;
    }
    .hero-opco-icon { font-size: 18px; flex-shrink: 0; line-height: 1.3; }
    .hero-opco strong { font-weight: 600; color: var(--gold); display: block; margin-bottom: 2px; }
    .hero-opco span { font-size: 13px; color: var(--sub); }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
    .hero-stats {
      display: flex;
      align-items: center;
      padding-top: 28px;
      border-top: 1px solid var(--line);
      flex-wrap: wrap;
      gap: 0;
    }
    .hero-stat { display: flex; align-items: center; }
    .hero-stat-sep { width: 1px; height: 30px; background: var(--line); margin: 0 20px; }
    .hero-stat-v { font-family: 'Cormorant Garamond', serif; font-size: 18px; color: var(--ink); font-weight: 500; line-height: 1.1; margin-bottom: 2px; }
    .hero-stat-l { font-size: 10px; color: var(--faint); }

    /* ── Carte hero droite ── */
    .hero-card {
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(0,0,0,0.07);
    }
    .hero-card-head {
      background: var(--navy);
      padding: 32px 28px 28px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .hero-card-head-note {
      margin-top: 20px;
      width: 100%;
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: 16px;
      text-align: center;
      font-size: 11px;
      color: rgba(255,255,255,0.32);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .hero-card-body { padding: 24px 28px; }
    .hero-card-list { display: flex; flex-direction: column; gap: 11px; margin-bottom: 22px; }
    .hero-card-item { display: flex; align-items: center; gap: 12px; font-size: 13px; color: var(--sub); }
    .hero-card-phone {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--lineS);
    }
    .hero-card-phone a { font-size: 14px; color: var(--ink); font-weight: 500; text-decoration: none; display: block; }
    .hero-card-phone p { font-size: 11px; color: var(--faint); }

    /* ════════════════════════════════════
       TRUST BAR
    ════════════════════════════════════ */
    .trust-bar {
      background: var(--white);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      padding: 20px 36px;
    }
    .trust-bar-inner {
      max-width: 1080px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .trust-item { display: flex; align-items: center; gap: 10px; flex: 1 1 150px; }
    .trust-sep { width: 1px; height: 30px; background: var(--line); flex-shrink: 0; }
    .trust-label { font-size: 13px; color: var(--ink); font-weight: 500; }
    .trust-sub { font-size: 11px; color: var(--faint); }

    /* ════════════════════════════════════
       SECTION OPCO
    ════════════════════════════════════ */
    .opco-section { background: var(--navy); padding: 96px 36px; }
    .opco-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 96px;
      align-items: center;
      margin-bottom: 72px;
      padding-bottom: 56px;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .opco-grid h2 { color: #EDE8DF; line-height: 1.0; margin-bottom: 22px; }
    .opco-grid h2 em { color: var(--gold); }
    .opco-grid p { font-size: 15px; color: rgba(255,255,255,0.55); line-height: 1.85; margin-bottom: 32px; }
    .opco-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 16px;
    }
    .opco-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 14px 16px;
    }
    .opco-card strong { font-size: 13px; color: #EDE8DF; display: block; margin-bottom: 3px; font-weight: 500; }
    .opco-card span { font-size: 11px; color: rgba(255,255,255,0.35); }
    .opco-carsat {
      background: rgba(150,112,14,0.12);
      border: 1px solid rgba(150,112,14,0.25);
      border-radius: 10px;
      padding: 14px 18px;
      font-size: 13px;
      color: var(--gold);
      line-height: 1.7;
    }

    /* Processus */
    .process-title {
      font-size: 10px;
      color: rgba(255,255,255,0.3);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 40px;
      font-weight: 600;
    }
    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
    .process-item { position: relative; }
    .process-num-wrap {
      width: 30px; height: 30px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.15);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px;
    }
    .process-num { font-family: 'Cormorant Garamond', serif; font-size: 12px; color: rgba(255,255,255,0.4); font-style: italic; }
    .process-t { font-size: 15px; color: #EDE8DF; font-weight: 500; margin-bottom: 8px; }
    .process-d { font-size: 13px; color: rgba(255,255,255,0.42); line-height: 1.65; }

    /* ════════════════════════════════════
       FORMATIONS
    ════════════════════════════════════ */
    .formations-section { padding: 96px 0; }
    .formations-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      align-items: end;
      margin-bottom: 48px;
    }
    .formations-header h2 { line-height: 1.05; }
    .formations-header h2 em { color: var(--red); }
    .formations-header p { font-size: 14px; color: var(--sub); line-height: 1.85; }

    /* Table */
    .f-table {
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: 18px;
      overflow: hidden;
      margin-bottom: 20px;
    }
    .f-head {
      display: grid;
      grid-template-columns: 40px 1fr 120px 120px 140px 110px;
      gap: 16px;
      padding: 12px 28px;
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }
    .f-head span { font-size: 10px; color: var(--faint); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; }
    .f-row {
      display: grid;
      grid-template-columns: 40px 1fr 120px 120px 140px 110px;
      gap: 16px;
      padding: 22px 28px;
      border-bottom: 1px solid var(--lineS);
      align-items: center;
      transition: background 0.2s, padding-left 0.25s;
    }
    .f-row:last-child { border-bottom: none; }
    .f-row:hover { background: var(--paper); padding-left: 36px; }
    .f-num { font-family: 'Cormorant Garamond', serif; font-size: 12px; color: var(--faint); font-style: italic; }
    .f-tag { font-size: 9px; font-weight: 700; color: var(--red); letter-spacing: 0.12em; text-transform: uppercase; margin-right: 8px; }
    .f-name { font-family: 'Cormorant Garamond', serif; font-size: 15px; color: var(--ink); font-weight: 400; margin: 6px 0 3px; }
    .f-desc { font-size: 12px; color: var(--sub); line-height: 1.5; }
    .f-price { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: var(--ink); font-weight: 500; }
    .f-price-sub { font-size: 10px; color: var(--faint); }
    .f-dur { font-size: 13px; color: var(--ink); }
    .f-rec { font-size: 11px; color: var(--sub); }
    .f-opco { font-size: 10px; color: var(--gold); margin-top: 3px; font-weight: 500; }

    .opco-note {
      background: rgba(150,112,14,0.10);
      border: 1px solid rgba(150,112,14,0.22);
      border-radius: 12px;
      padding: 18px 24px;
      display: flex;
      align-items: flex-start;
      gap: 14px;
      font-size: 14px;
      color: var(--ink);
      line-height: 1.7;
    }
    .opco-note a { color: var(--gold); font-weight: 600; }

    /* ════════════════════════════════════
       APPROCHE
    ════════════════════════════════════ */
    .approche-section { padding: 96px 0; }
    .approche-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 96px;
    }
    .approche-grid h2 { margin-bottom: 22px; line-height: 1.07; }
    .approche-compass { margin-bottom: 24px; display: inline-block; transition: transform 0.6s ease; }
    .approche-compass:hover { transform: rotate(15deg); }
    .approche-quote {
      font-size: 13px;
      color: var(--sub);
      line-height: 1.8;
      font-style: italic;
      border-left: 2px solid var(--red);
      padding-left: 16px;
    }
    .approche-list { display: flex; flex-direction: column; }
    .approche-item { display: flex; gap: 20px; padding: 20px 0; border-bottom: 1px solid var(--lineS); }
    .approche-n { font-family: 'Cormorant Garamond', serif; font-size: 12px; color: var(--faint); min-width: 24px; padding-top: 3px; font-style: italic; flex-shrink: 0; }
    .approche-t { font-size: 15px; color: var(--ink); font-weight: 500; margin-bottom: 5px; }
    .approche-d { font-size: 13px; color: var(--sub); line-height: 1.65; }

    /* ════════════════════════════════════
       TEMOIGNAGES PLACEHOLDER
    ════════════════════════════════════ */
    .temoignages-placeholder {
      background: var(--lineS);
      padding: 48px 36px;
      text-align: center;
    }
    .temoignages-placeholder h3 { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: var(--muted); font-style: italic; margin-bottom: 10px; }
    .temoignages-placeholder p { font-size: 13px; color: var(--faint); }

    /* ════════════════════════════════════
       FAQ
    ════════════════════════════════════ */
    .faq-section { padding: 96px 0; }
    .faq-grid {
      display: grid;
      grid-template-columns: 300px 1fr;
      gap: 96px;
    }
